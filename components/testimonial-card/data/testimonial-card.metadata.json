{
  "identity": {
    "name": "TestimonialCard",
    "description": "Tarjeta de testimonio con cita, avatar, nombre del autor y empresa. Diseñada para bloques de social proof.",
    "family": "card",
    "version": "1.0.0"
  },
  "usage": {
    "purpose": "Mostrar un testimonio individual de un cliente o usuario.",
    "useCases": ["landing page testimonials", "review carousel", "case study sidebar"],
    "notUseCases": ["review form", "rating aggregation", "comment thread"]
  },
  "business": {
    "domains": ["marketing", "social"],
    "scenarios": ["landing page social proof", "product review section", "customer showcase"],
    "priority": "core"
  },
  "businessData": [
    { "name": "authorName", "type": "string", "required": true, "description": "Nombre del autor", "domain": "social" },
    { "name": "authorRole", "type": "string", "required": false, "description": "Cargo del autor", "domain": "social" },
    { "name": "company", "type": "string", "required": false, "description": "Empresa del autor", "domain": "marketing" },
    { "name": "quote", "type": "string", "required": true, "description": "Texto del testimonio", "domain": "marketing" },
    { "name": "avatarUrl", "type": "string", "required": false, "description": "Avatar del autor", "domain": "social" },
    { "name": "rating", "type": "number", "required": false, "description": "Puntuación 1-5", "domain": "marketing" }
  ],
  "composition": {
    "isListable": true,
    "compatibleWith": ["TestimonialGrid", "ReviewCarousel"],
    "requires": []
  },
  "props": [
    { "name": "authorName", "type": "string", "required": true, "description": "Nombre del autor" },
    { "name": "authorRole", "type": "string", "required": false, "description": "Cargo" },
    { "name": "company", "type": "string", "required": false, "description": "Empresa" },
    { "name": "quote", "type": "string", "required": true, "description": "Texto del testimonio" },
    { "name": "avatarUrl", "type": "string", "required": false, "description": "URL del avatar" },
    { "name": "rating", "type": "number", "required": false, "description": "Rating 1-5" }
  ],
  "state": [
    { "name": "isHovered", "type": "boolean", "initial": "false", "description": "Hover activo" }
  ],
  "modifiers": [
    { "dataId": "testimonial-card-hovered", "description": "Sombra sutil en hover", "appliesWhen": "isHovered === true" }
  ],
  "interactions": [
    { "event": "onMouseEnter", "handler": "setIsHovered(true)", "description": "Hover on" },
    { "event": "onMouseLeave", "handler": "setIsHovered(false)", "description": "Hover off" }
  ],
  "stateToUI": [
    { "state": "isHovered", "modifier": "testimonial-card-hovered", "description": "Hover eleva tarjeta" }
  ],
  "variants": [
    { "name": "withRating", "description": "Muestra estrellas de rating", "props": { "rating": "5" } },
    { "name": "minimal", "description": "Solo cita y nombre, sin avatar ni empresa", "props": {} }
  ],
  "rules": [
    "must display quote and authorName",
    "must truncate quote to 200 chars max",
    "must show rating stars only when rating is provided"
  ],
  "conditions": [
    { "if": "rating is provided", "then": "render star icons" },
    { "if": "avatarUrl is empty", "then": "render initials fallback" }
  ],
  "tokens": {
    "borderRadius": "radius-lg",
    "spacing": "space-4",
    "quoteFont": "text-base italic",
    "authorFont": "text-sm font-medium"
  },
  "package": {
    "name": "@small-organism/testimonial-card",
    "version": "1.0.0",
    "path": "components/testimonial-card"
  },
  "externalDependencies": [],
  "organism": {
    "type": "small-organism",
    "restrictions": {
      "noGlobalState": true,
      "noNestedOrganisms": true,
      "localStateOnly": true
    }
  },
  "complexity": "low"
}
