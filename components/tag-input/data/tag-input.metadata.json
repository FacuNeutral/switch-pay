{
  "identity": {
    "name": "TagInput",
    "description": "Input que permite agregar y remover tags/chips. El usuario escribe y presiona Enter para crear un tag. Cada tag tiene un botón de eliminar.",
    "family": "input",
    "version": "1.0.0"
  },
  "usage": {
    "purpose": "Permitir al usuario crear y gestionar una lista de tags de forma interactiva.",
    "useCases": ["blog post tags", "skill selector in profile", "keyword filter input"],
    "notUseCases": ["dropdown select", "radio group", "single text input"]
  },
  "business": {
    "domains": ["saas", "content", "dashboard"],
    "scenarios": ["CMS tag editor", "user skill profile", "dashboard filter bar"],
    "priority": "secondary"
  },
  "businessData": [
    { "name": "tags", "type": "string[]", "required": true, "description": "Tags actuales", "domain": "content" }
  ],
  "composition": {
    "isListable": false,
    "compatibleWith": ["FilterBar", "FormSection"],
    "requires": []
  },
  "props": [
    { "name": "value", "type": "string[]", "required": true, "description": "Tags actuales" },
    { "name": "onChange", "type": "(tags: string[]) => void", "required": true, "description": "Callback al cambiar tags" },
    { "name": "placeholder", "type": "string", "required": false, "default": "Add tag...", "description": "Placeholder del input" },
    { "name": "maxTags", "type": "number", "required": false, "default": "10", "description": "Máximo de tags permitidos" }
  ],
  "state": [
    { "name": "inputValue", "type": "string", "initial": "''", "description": "Valor del campo de texto" },
    { "name": "isFocused", "type": "boolean", "initial": "false", "description": "El input tiene foco" }
  ],
  "modifiers": [
    { "dataId": "tag-input-focused", "description": "Borde de acento cuando tiene foco", "appliesWhen": "isFocused === true" }
  ],
  "interactions": [
    { "event": "onKeyDown (Enter)", "handler": "addTag(inputValue)", "description": "Agrega el tag" },
    { "event": "onKeyDown (Backspace)", "handler": "removeLastTag()", "description": "Elimina último tag si input vacío" },
    { "event": "onClick (tag X)", "handler": "removeTag(tag)", "description": "Elimina tag específico" },
    { "event": "onFocus", "handler": "setIsFocused(true)", "description": "Marca foco" },
    { "event": "onBlur", "handler": "setIsFocused(false)", "description": "Pierde foco" }
  ],
  "stateToUI": [
    { "state": "isFocused", "modifier": "tag-input-focused", "description": "Borde de acento en foco" }
  ],
  "variants": [
    { "name": "default", "description": "Tags en línea con input al final", "props": {} }
  ],
  "rules": [
    "must not allow duplicate tags",
    "must not allow empty tags",
    "must respect maxTags limit",
    "must trim whitespace from tag values"
  ],
  "conditions": [
    { "if": "value.length >= maxTags", "then": "disable input" },
    { "if": "inputValue is empty and Backspace pressed", "then": "remove last tag" }
  ],
  "tokens": {
    "borderRadius": "radius-md",
    "tagBg": "bg-zinc-700",
    "tagText": "text-xs",
    "focusBorder": "border-indigo-500",
    "spacing": "gap-1.5"
  },
  "package": {
    "name": "@small-organism/tag-input",
    "version": "1.0.0",
    "path": "components/tag-input"
  },
  "externalDependencies": [],
  "organism": {
    "type": "small-organism",
    "restrictions": {
      "noGlobalState": true,
      "noNestedOrganisms": true,
      "localStateOnly": true
    }
  },
  "complexity": "medium"
}
