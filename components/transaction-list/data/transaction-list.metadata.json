{
  "identity": {
    "name": "TransactionList",
    "description": "Lista de transacciones con monto, descripción, fecha y estado (completada, pendiente, fallida). Cada fila es clickeable para ver detalle.",
    "family": "list",
    "version": "1.0.0"
  },
  "usage": {
    "purpose": "Mostrar un historial de transacciones financieras con estado y montos.",
    "useCases": ["payment history page", "wallet dashboard", "admin transaction log"],
    "notUseCases": ["payment form", "checkout flow", "invoice generator"]
  },
  "business": {
    "domains": ["ecommerce", "saas", "dashboard"],
    "scenarios": ["user payment history", "admin revenue dashboard", "wallet balance detail"],
    "priority": "core"
  },
  "businessData": [
    { "name": "transactionId", "type": "string", "required": true, "description": "ID de la transacción", "domain": "ecommerce" },
    { "name": "description", "type": "string", "required": true, "description": "Descripción del pago", "domain": "ecommerce" },
    { "name": "amount", "type": "number", "required": true, "description": "Monto de la transacción", "domain": "ecommerce" },
    { "name": "currency", "type": "string", "required": false, "description": "Moneda (USD, EUR)", "domain": "ecommerce" },
    { "name": "status", "type": "string", "required": true, "description": "completed | pending | failed", "domain": "ecommerce" },
    { "name": "date", "type": "string", "required": true, "description": "Fecha ISO 8601", "domain": "ecommerce" }
  ],
  "composition": {
    "isListable": true,
    "compatibleWith": ["WalletDashboard", "PaymentHistory"],
    "requires": []
  },
  "props": [
    { "name": "transactions", "type": "Transaction[]", "required": true, "description": "Lista de transacciones" },
    { "name": "onSelect", "type": "(id: string) => void", "required": false, "description": "Callback al seleccionar transacción" }
  ],
  "state": [
    { "name": "selectedId", "type": "string | null", "initial": "null", "description": "Transacción actualmente seleccionada" }
  ],
  "modifiers": [
    { "dataId": "tx-selected", "description": "Borde izquierdo de acento", "appliesWhen": "selectedId === transactionId" },
    { "dataId": "tx-status-failed", "description": "Texto rojo para transacciones fallidas", "appliesWhen": "status === 'failed'" }
  ],
  "interactions": [
    { "event": "onClick (row)", "handler": "setSelectedId(id); onSelect(id)", "description": "Selecciona transacción" }
  ],
  "stateToUI": [
    { "state": "selectedId", "modifier": "tx-selected", "description": "Destaca la fila seleccionada" }
  ],
  "variants": [
    { "name": "compact", "description": "Sin columna de status, solo monto y descripción", "props": {} },
    { "name": "withCurrency", "description": "Muestra moneda junto al monto", "props": {} }
  ],
  "rules": [
    "must display amount with 2 decimal places",
    "must color-code status badges (green/yellow/red)",
    "must show transactions in reverse chronological order"
  ],
  "conditions": [
    { "if": "status === 'failed'", "then": "show red badge" },
    { "if": "amount < 0", "then": "show as debit with minus sign" },
    { "if": "transactions.length === 0", "then": "show empty state" }
  ],
  "tokens": {
    "spacing": "space-0",
    "fontAmount": "text-sm font-mono",
    "fontDescription": "text-sm",
    "statusCompleted": "text-emerald-400",
    "statusPending": "text-amber-400",
    "statusFailed": "text-red-400"
  },
  "package": {
    "name": "@small-organism/transaction-list",
    "version": "1.0.0",
    "path": "components/transaction-list"
  },
  "externalDependencies": [],
  "organism": {
    "type": "small-organism",
    "restrictions": {
      "noGlobalState": true,
      "noNestedOrganisms": true,
      "localStateOnly": true
    }
  },
  "complexity": "medium"
}
