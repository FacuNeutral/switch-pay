{
  "identity": {
    "name": "DateRangeSelector",
    "description": "Selector de rango de fechas con inputs de 'desde' y 'hasta', presets rápidos (7d, 30d, 90d) y botón de aplicar. Sin calendario desplegable (usa native date inputs).",
    "family": "input",
    "version": "1.0.0"
  },
  "usage": {
    "purpose": "Permitir al usuario seleccionar un rango de fechas para filtrar datos.",
    "useCases": ["analytics dashboard filter", "booking date selection", "report date range"],
    "notUseCases": ["single date picker", "calendar month view", "scheduling grid"]
  },
  "business": {
    "domains": ["dashboard", "saas", "ecommerce"],
    "scenarios": ["analytics date filter", "sales report period", "booking check-in/check-out"],
    "priority": "core"
  },
  "businessData": [
    { "name": "startDate", "type": "string", "required": true, "description": "Fecha inicio ISO", "domain": "dashboard" },
    { "name": "endDate", "type": "string", "required": true, "description": "Fecha fin ISO", "domain": "dashboard" }
  ],
  "composition": {
    "isListable": false,
    "compatibleWith": ["FilterBar", "AnalyticsHeader"],
    "requires": []
  },
  "props": [
    { "name": "startDate", "type": "string", "required": true, "description": "Fecha inicio YYYY-MM-DD" },
    { "name": "endDate", "type": "string", "required": true, "description": "Fecha fin YYYY-MM-DD" },
    { "name": "onChange", "type": "(start: string, end: string) => void", "required": true, "description": "Callback al cambiar rango" },
    { "name": "presets", "type": "DatePreset[]", "required": false, "description": "Presets rápidos" }
  ],
  "state": [
    { "name": "localStart", "type": "string", "initial": "startDate", "description": "Valor local de fecha inicio" },
    { "name": "localEnd", "type": "string", "initial": "endDate", "description": "Valor local de fecha fin" }
  ],
  "modifiers": [
    { "dataId": "date-range-invalid", "description": "Borde rojo si start > end", "appliesWhen": "localStart > localEnd" }
  ],
  "interactions": [
    { "event": "onChange (start input)", "handler": "setLocalStart(value)", "description": "Actualiza fecha inicio" },
    { "event": "onChange (end input)", "handler": "setLocalEnd(value)", "description": "Actualiza fecha fin" },
    { "event": "onClick (preset)", "handler": "applyPreset(preset)", "description": "Aplica preset rápido" },
    { "event": "onClick (apply)", "handler": "onChange(localStart, localEnd)", "description": "Confirma el rango" }
  ],
  "stateToUI": [
    { "state": "localStart > localEnd", "modifier": "date-range-invalid", "description": "Error visual si rango inválido" }
  ],
  "variants": [
    { "name": "inline", "description": "Inputs en línea sin botón apply", "props": {} },
    { "name": "withPresets", "description": "Muestra botones de presets rápidos", "props": {} }
  ],
  "rules": [
    "must validate that startDate is not after endDate",
    "must apply preset relative to current date",
    "must not allow future dates beyond today"
  ],
  "conditions": [
    { "if": "localStart > localEnd", "then": "show validation error and disable apply" },
    { "if": "presets provided", "then": "render preset buttons" }
  ],
  "tokens": {
    "borderRadius": "radius-md",
    "inputBg": "bg-zinc-800",
    "activeBorder": "border-indigo-500",
    "errorBorder": "border-red-500",
    "spacing": "gap-2"
  },
  "package": {
    "name": "@small-organism/date-range-selector",
    "version": "1.0.0",
    "path": "components/date-range-selector"
  },
  "externalDependencies": [],
  "organism": {
    "type": "small-organism",
    "restrictions": {
      "noGlobalState": true,
      "noNestedOrganisms": true,
      "localStateOnly": true
    }
  },
  "complexity": "medium"
}
